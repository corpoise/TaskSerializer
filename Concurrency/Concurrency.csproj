  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Systems\Systems.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Concurrency.Tests" />
  </ItemGroup>

</Project>
