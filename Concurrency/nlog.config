<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true">

  <variable name="logLayout"
            value="${longdate}|${level:uppercase=true}|${logger:shortName=true}|${message}|${exception:format=tostring}" />

  <targets>
    <target xsi:type="File"
            name="file"
            fileName="logs/${date:format=yyyy-MM-dd_HH_mm}_00.txt"
            layout="${logLayout}"
            keepFileOpen="true"
            concurrentWrites="false"
            encoding="utf-8" />

    <target xsi:type="Console"
            name="console"
            layout="${logLayout}" />
  </targets>

  <rules>
    <logger name="Systems.*" minlevel="Info" writeTo="file,console" />
  </rules>

</nlog>
